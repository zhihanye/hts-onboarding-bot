# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic (Claude) API - 用于识别截图中的邮箱
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Outlook 邮件发送（Microsoft Graph API）
OUTLOOK_EMAIL=your_outlook_email@company.com

# Azure AD 应用信息（委托登录，不需要 Client Secret）
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id

# 发件人显示名称
SENDER_NAME=Florian
